{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "featuredImage": {
      "type": "string"
    },
    "featuredImageAlt": {
      "type": "string"
    },
    "rssOnly": {
      "default": false,
      "type": "boolean"
    },
    "draft": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "pubDate",
    "description"
  ]
}